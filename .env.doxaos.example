# ============================================================================
# DoxaOS Phase 0 Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git

# ============================================================================
# SUPABASE
# ============================================================================
# Get these from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
DATABASE_URL=postgresql://postgres:password@your-project.supabase.co:5432/postgres

# ============================================================================
# STRIPE
# ============================================================================
# Get from your Stripe Dashboard
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Stripe Product IDs (create these in Stripe Dashboard)
STRIPE_STARTER_PRICE_ID=price_starter_id
STRIPE_GROWTH_PRICE_ID=price_growth_id
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_id

# ============================================================================
# ANTHROPIC (AI Advisor)
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ============================================================================
# RESEND (Email)
# ============================================================================
RESEND_API_KEY=re_your-key-here
RESEND_FROM_EMAIL=hello@doxaandco.com

# ============================================================================
# CLOUDFLARE R2 (File Storage)
# ============================================================================
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=doxaos-files
R2_PUBLIC_URL=https://your-bucket.r2.cloudflarestorage.com

# ============================================================================
# APP SETTINGS
# ============================================================================
VITE_APP_URL=http://localhost:5173
VITE_SITE_URL=http://localhost:5173

# ============================================================================
# NOTES
# ============================================================================
# 1. Start with Phase 0: Supabase + Prisma
# 2. Run: DATABASE_URL=... npx prisma migrate deploy
# 3. Run: psql -f prisma/rls-policies.sql (to apply RLS)
# 4. Set Stripe webhook: POST /api/webhooks/stripe
# 5. Configure Supabase Auth redirects: localhost:5173, doxaandco.co
